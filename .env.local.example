# Runtime Optimizer Configuration
# Set to 'true' to enable runtime container optimization
RUNTIME_OPTIMIZER_ENABLED=true

# Aggressive mode removes documentation and locale files (more space saving)
RUNTIME_OPTIMIZER_AGGRESSIVE=false

# Dry-run mode logs what would be deleted without actually deleting
RUNTIME_OPTIMIZER_DRY_RUN=false

# Note: Copy this file to .env.local and adjust settings as needed
