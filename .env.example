# Environment Configuration for Docker Optimizer

# AWS Configuration
# These credentials are used for ECR and ECS operations
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: Specific AWS Account ID (detected automatically if not provided)
# AWS_ACCOUNT_ID=123456789012

# ECR Configuration
# ECR_REGISTRY_URL will be auto-detected from credentials
# Format: <account-id>.dkr.ecr.<region>.amazonaws.com
# ECR_REGISTRY_URL=123456789012.dkr.ecr.us-east-1.amazonaws.com

# ECS Configuration
# Default ECS cluster (optional - can be selected in UI)
# ECS_CLUSTER_NAME=docker-optimizer-cluster
# ECS_SERVICE_NAME=optimizer-service

# Default ECS Task Configuration
# ECS_TASK_CPU=256
# ECS_TASK_MEMORY=512

# Network Configuration for ECS (required for deployment)
# Get these from your AWS VPC console
# ECS_SUBNET_IDS=subnet-xxxxx,subnet-yyyyy
# ECS_SECURITY_GROUP_IDS=sg-xxxxx

# Runtime Optimizer Configuration
RUNTIME_OPTIMIZER_ENABLED=true
RUNTIME_OPTIMIZER_AGGRESSIVE=false
RUNTIME_OPTIMIZER_DRY_RUN=false

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
